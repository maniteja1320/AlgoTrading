# Delta Exchange India API credentials (create at india.delta.exchange → API Management)
DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here

# Environment: testnet | production
DELTA_ENV=production

# Comma-separated origins (add Railway frontend URL after deploy)
CORS_ORIGINS=http://localhost:5173,https://YOUR-FRONTEND.up.railway.app

# Order alert emails via Resend (https://resend.com — works local + Railway)
# 1. Create API key at https://resend.com/api-keys
# 2. For testing without a domain: ALERT_EMAIL_FROM=onboarding@resend.dev (sends to your Resend account email only)
# 3. For production: verify a domain in Resend, then use e.g. alerts@yourdomain.com
RESEND_API_KEY=re_your_api_key_here
ALERT_EMAIL_FROM=onboarding@resend.dev
ALERT_EMAIL_TO=your_recipient@gmail.com

# Web push notifications (optional — run: python scripts/generate_vapid_keys.py)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:your_email@gmail.com

# Push delivery log file (optional — auto-off on Railway; set false to disable locally)
# PUSH_LOG_ENABLED=false
